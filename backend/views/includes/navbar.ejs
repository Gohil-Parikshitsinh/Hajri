<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hajri Sliding Navbar</title>
  <!-- 1. Your Tailwind config override -->
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          primary: '#2684FF',
          'primary-hover': '#1e6fcb'
          // add more custom colors here
        }
      }
    }
  }
</script>

<!-- 2. Then load Tailwind -->
<script src="https://cdn.tailwindcss.com"></script>

</head>
<body class="bg-white dark:bg-[#121212] text-[#111] dark:text-[#f9f9f9]">

  <!-- Navbar -->
  <div class="flex items-center justify-between p-4 border-b border-[#e0e0e0] dark:border-[#2a2a2a] bg-white dark:bg-[#121212]">
    <button id="openSidebar" class="text-2xl">&#9776;</button>
    <h1 class="text-xl font-semibold">Hajri</h1>
  </div>

  <!-- Sidebar -->
  <div id="sidebar" class="fixed top-0 left-0 h-full w-64 bg-[#f9f9f9] dark:bg-[#1e1e1e] border-r border-[#e0e0e0] dark:border-[#2a2a2a] transform -translate-x-full transition-transform duration-300 z-50">
    <div class="flex items-center justify-between p-4 border-b border-[#e0e0e0] dark:border-[#2a2a2a]">
      <h2 class="text-lg font-bold">Menu</h2>
      <button id="closeSidebar" class="text-xl">&times;</button>
    </div>
    <nav class="p-4 flex flex-col gap-4">
      <a href="#" class="hover:bg-[#f0f0f0] dark:hover:bg-[#2f2f2f] p-2 rounded">Dashboard</a>
      <a href="#" class="hover:bg-[#f0f0f0] dark:hover:bg-[#2f2f2f] p-2 rounded">Attendance</a>
      <a href="#" class="hover:bg-[#f0f0f0] dark:hover:bg-[#2f2f2f] p-2 rounded">Employees</a>
      <a href="#" class="hover:bg-[#f0f0f0] dark:hover:bg-[#2f2f2f] p-2 rounded">Reports</a>
      <a href="#" class="hover:bg-[#f0f0f0] dark:hover:bg-[#2f2f2f] p-2 rounded text-[#d73a49]">Logout</a>
    </nav>
  </div>

  <!-- Page Content -->
  <div class="p-6">
    <p>Welcome to Hajri Dashboard</p>
  </div>

  <!-- JavaScript -->
  <script>
    const openBtn = document.getElementById('openSidebar');
    const closeBtn = document.getElementById('closeSidebar');
    const sidebar = document.getElementById('sidebar');

    openBtn.addEventListener('click', () => {
      sidebar.classList.remove('-translate-x-full');
    });

    closeBtn.addEventListener('click', () => {
      sidebar.classList.add('-translate-x-full');
    });
  </script>
</body>
</html>
