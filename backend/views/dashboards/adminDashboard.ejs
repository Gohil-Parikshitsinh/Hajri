<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hajri Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Hajri Color Scheme via CDN Tailwind config -->
  

</head>
<body class="bg-white dark:bg-[#121212] text-[#111111] dark:text-[#f9f9f9] min-h-screen">

  <!-- Header -->
  <header class="p-4 border-b border-borderlight dark:border-borderdark bg-white dark:bg-[#121212]">
    <h1 class="text-2xl font-semibold">📊 Hajri Dashboard</h1>
  </header>

  <!-- Main Content -->
  <main class="p-6 space-y-6">

    <!-- Top Stat Cards -->
    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Employees Card -->
      <div class="bg-[#f9f9f9] dark:bg-[#1e1e1e] p-6 rounded-2xl shadow border border-borderlight dark:border-borderdark">
        <div class="text-lg font-medium mb-2">👥 Employees</div>
        <div class="text-3xl font-bold">128</div>
        <div class="text-sm text-[#555] dark:text-[#aaa] mt-1">Active employees</div>
      </div>

      <!-- Salary Card -->
      <div class="bg-[#f9f9f9] dark:bg-[#1e1e1e] p-6 rounded-2xl shadow border border-borderlight dark:border-borderdark">
        <div class="text-lg font-medium mb-2">💸 Total Salary Paid</div>
        <div class="text-3xl font-bold">₹12,40,000</div>
        <div class="text-sm text-[#555] dark:text-[#aaa] mt-1">Till this month</div>
      </div>

      <!-- Next Payout -->
      <div class="bg-[#f9f9f9] dark:bg-[#1e1e1e] p-6 rounded-2xl shadow border border-borderlight dark:border-borderdark">
        <div class="text-lg font-medium mb-2">🗓️ Next Payout</div>
        <div class="text-3xl font-bold">07 July, 2025</div>
        <div class="text-sm text-[#555] dark:text-[#aaa] mt-1">Scheduled date</div>
      </div>
    </section>

    <!-- Lower Grid -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Recent Attendance -->
      <div class="bg-[#f9f9f9] dark:bg-[#1e1e1e] p-6 rounded-2xl shadow border border-borderlight dark:border-borderdark">
        <h2 class="text-xl font-semibold mb-4">📅 Recent Attendance</h2>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between">
            <span>Parth Patel</span>
            <span class="text-green-600">Present</span>
          </li>
          <li class="flex justify-between">
            <span>Meera Shah</span>
            <span class="text-red-600">Absent</span>
          </li>
          <li class="flex justify-between">
            <span>Amit Joshi</span>
            <span class="text-green-600">Present</span>
          </li>
        </ul>
      </div>

      <!-- Quick Actions -->
      <div class="bg-[#f9f9f9] dark:bg-[#1e1e1e] p-6 rounded-2xl shadow border border-borderlight dark:border-borderdark">
        <h2 class="text-xl font-semibold mb-4">⚡ Quick Actions</h2>
        <div class="flex flex-wrap gap-4">
          <button class="bg-[#2684FF] text-white hover:bg-[#1e6fcb] px-4 py-2 rounded-xl">➕ Add Employee</button>
          <button class="bg-[#2684FF] text-white hover:bg-[#1e6fcb] px-4 py-2 rounded-xl">📤 Generate Payslip</button>
          <button class="bg-[#2684FF] text-white hover:bg-[#1e6fcb] px-4 py-2 rounded-xl">📁 Download Report</button>
        </div>
      </div>

    </section>

  </main>

</body>
</html>
